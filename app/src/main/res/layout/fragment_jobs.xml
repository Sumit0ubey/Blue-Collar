<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    tools:context=".ui.myjobs.JobsFragment">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="16dp">

        <TextView
            android:id="@+id/current_jobs_header"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="Current Jobs"
            android:textAppearance="?attr/textAppearanceHeadline5"
            android:textStyle="bold"
            app:drawableEndCompat="@drawable/ic_keyboard_arrow_up"
            app:layout_constraintEnd_toStartOf="@id/refresh_current_jobs"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <ImageButton
            android:id="@+id/refresh_current_jobs"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@android:drawable/ic_menu_rotate"
            app:layout_constraintBottom_toBottomOf="@+id/current_jobs_header"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="@+id/current_jobs_header"
            android:contentDescription="Refresh Current Jobs" />

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/current_jobs_recycler_view"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:nestedScrollingEnabled="false"
            android:visibility="gone"
            app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/current_jobs_header"
            tools:itemCount="2"
            tools:listitem="@layout/item_job"
            tools:visibility="visible" />

        <TextView
            android:id="@+id/current_jobs_empty"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="No current jobs found"
            android:visibility="gone"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/current_jobs_header"
            tools:visibility="visible" />

        <androidx.constraintlayout.widget.Group
            android:id="@+id/current_jobs_group"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:visibility="visible"
            app:constraint_referenced_ids="current_jobs_recycler_view,current_jobs_empty" />

        <androidx.constraintlayout.widget.Barrier
            android:id="@+id/current_jobs_barrier"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:barrierDirection="bottom"
            app:constraint_referenced_ids="current_jobs_recycler_view,current_jobs_empty" />

        <TextView
            android:id="@+id/previous_jobs_header"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="32dp"
            android:text="Previous Jobs"
            android:textAppearance="?attr/textAppearanceHeadline5"
            android:textStyle="bold"
            app:drawableEndCompat="@drawable/ic_keyboard_arrow_up"
            app:layout_constraintEnd_toStartOf="@id/refresh_previous_jobs"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/current_jobs_barrier" />

        <ImageButton
            android:id="@+id/refresh_previous_jobs"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@android:drawable/ic_menu_rotate"
            app:layout_constraintBottom_toBottomOf="@+id/previous_jobs_header"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="@+id/previous_jobs_header"
            android:contentDescription="Refresh Previous Jobs" />

        <LinearLayout
            android:id="@+id/previous_jobs_filter_container"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/previous_jobs_header">

            <com.google.android.material.chip.ChipGroup
                android:id="@+id/previous_jobs_filter_group"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:selectionRequired="true"
                app:singleSelection="true">

                <com.google.android.material.chip.Chip
                    android:id="@+id/chip_today"
                    style="@style/Widget.MaterialComponents.Chip.Filter"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:checked="true"
                    android:text="Today" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/chip_this_week"
                    style="@style/Widget.MaterialComponents.Chip.Filter"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="This Week" />

            </com.google.android.material.chip.ChipGroup>

            <TextView
                android:id="@+id/chip_clear"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:clickable="true"
                android:focusable="true"
                android:fontFamily="sans-serif-medium"
                android:text="Clear"
                android:textColor="?attr/colorPrimary"
                android:visibility="gone"
                tools:visibility="visible" />
        </LinearLayout>

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/previous_jobs_recycler_view"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:nestedScrollingEnabled="false"
            android:visibility="gone"
            app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/previous_jobs_filter_container"
            tools:itemCount="3"
            tools:listitem="@layout/item_job"
            tools:visibility="visible" />

        <TextView
            android:id="@+id/previous_jobs_empty"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="No previous jobs found"
            android:visibility="gone"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/previous_jobs_filter_container"
            tools:visibility="visible" />

        <androidx.constraintlayout.widget.Group
            android:id="@+id/previous_jobs_group"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:visibility="visible"
            app:constraint_referenced_ids="previous_jobs_recycler_view,previous_jobs_empty,previous_jobs_filter_container" />

        <ProgressBar
            android:id="@+id/jobs_progress"
            style="?android:attr/progressBarStyle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:visibility="gone"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>
</androidx.core.widget.NestedScrollView>
